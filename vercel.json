{
  "version": 2,

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },

  "routes": [
    {
      "src": "/build/(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "dest": "/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}